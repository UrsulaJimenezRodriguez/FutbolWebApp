38808>>>        Get HasRecord of hoDD to bHasRecord
38809>>>
38809>>>        // let's hide all buttons and then Show the ones we want
38809>>>        WebSet pbRender of oEditBtn to False
38810>>>        WebSet pbRender of oSaveBtn to False
38811>>>        WebSet pbRender of oCancelChangesBtn to False
38812>>>        WebSet pbRender of oDeleteBtn to False
38813>>>
38813>>>        If (NavigateData.bReadOnly) Begin
38815>>>            WebSet pbRender of oEditBtn to True
38816>>>        End
38816>>>>
38816>>>        Else Begin
38817>>>            WebSet pbRender of oSaveBtn to True
38818>>>            WebSet pbRender of oCancelChangesBtn to True
38819>>>            WebSet pbRender of oDeleteBtn to bHasRecord
38820>>>        End
38820>>>>
