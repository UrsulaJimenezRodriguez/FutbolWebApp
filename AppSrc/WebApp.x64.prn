38335>>>>>        WebSet pbRender of oNewButton to True
38336>>>>>        WebSet pbRender of oDetailButton to True
38337>>>>>
38337>>>>>        Case Begin
38337>>>>>            Case (NavigateData.eNavigateType = nfFromParent)
38339>>>>>                // If from parent, this is a constrained drill down
38339>>>>>                Case Break
38340>>>>>
38340>>>>>            Case (NavigateData.eNavigateType = nfFromChild)
38343>>>>>                // If from child, this is a probably a parent lookup from a Zoom
38343>>>>>                Case Break
38344>>>>>
38344>>>>>            Case (NavigateData.eNavigateType = nfFromMain)
38347>>>>>                // If from main, this is a probably a main-file lookup from a Zoom
38347>>>>>                WebSet pbRender of oDetailButton to False
38348>>>>>                Case Break
38349>>>>>
38349>>>>>            Case Else // must be nfUndefined
38349>>>>>                // This may be the start of a drilldown query or this may be used for some kind of custom query.
38349>>>>>
38349>>>>>        Case End
38349>>>>>
38349>>>>>    End_Procedure
