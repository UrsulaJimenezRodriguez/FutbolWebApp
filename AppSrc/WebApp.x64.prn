38831>>>    Procedure OnNavigateForward tWebNavigateData NavigateData Integer hoInvokingView Integer hoInvokingObject
38834>>>        Case Begin
38834>>>            Case (NavigateData.eNavigateType = nfFromMain)
38836>>>                // If from main, this is a propbably a main file Select to Zoom.
38836>>>                Case Break
38837>>>
38837>>>            Case (NavigateData.eNavigateType = nfFromParent)
38840>>>                // If from parent, this is a constrained drill down.
38840>>>                Case Break
38841>>>
38841>>>            Case (NavigateData.eNavigateType = nfFromChild)
38844>>>                // If from child, this is a probably a parent Zoom from a Zoom.
38844>>>                Case Break
38845>>>
38845>>>            Case Else // must be nfUndefined
38845>>>
38845>>>        Case End
38845>>>
38845>>>        Send SetActionButtons
38846>>>
38846>>>    End_Procedure
38847>>>
38847>>>End_Object 
